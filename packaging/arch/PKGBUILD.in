pkgname=cockpit-ai-agent
pkgver=VERSION
pkgrel=1
pkgdesc='AI-powered terminal assistant for Cockpit'
arch=('x86_64')
url='https://github.com/ShaoRou459/CockpitServerAI'
license=(LGPL)
source=("SOURCE")
sha256sums=('SKIP')

package() {
  depends=(cockpit)
  cd $pkgname
  make DESTDIR="$pkgdir" install PREFIX=/usr
}
